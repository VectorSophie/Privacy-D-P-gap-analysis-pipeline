# ─────────────────────────────────────────────
# OpenAI — LLM 평가 단계 (5단계 evaluate-llm)
# https://platform.openai.com/api-keys
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────
# Naver 검색 API — URL 미확인 기업 홈페이지 자동 탐색 (discover-urls 단계)
# https://developers.naver.com → 내 애플리케이션 → 검색 API 등록
# 무료 / 일 25,000회
# ─────────────────────────────────────────────
NAVER_CLIENT_ID=...
NAVER_CLIENT_SECRET=...

# ─────────────────────────────────────────────
# 공공데이터포털 — K-Startup 벤처기업 API (선택, collect-companies)
# configs/base.yaml의 collection.sources.kstartup.enabled: true 시 필요
# ─────────────────────────────────────────────
KSTARTUP_API_KEY=...
